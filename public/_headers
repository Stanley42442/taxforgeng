# Cache hashed assets for 1 year (filenames change on every build)
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Static file Content-Type headers for proper serving
/sitemap.xml
  Content-Type: application/xml

/robots.txt
  Content-Type: text/plain

/llms.txt
  Content-Type: text/plain; charset=utf-8

/llms-full.txt
  Content-Type: text/plain; charset=utf-8

/manifest.json
  Content-Type: application/manifest+json
